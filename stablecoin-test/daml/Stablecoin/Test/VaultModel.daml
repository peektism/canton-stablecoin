-- | Pure state-machine model of daml-stablecoin vault system.
-- Models the vault arithmetic without Script effects.
-- Follows DamlProps/Dogfood/SimpleToken/Model.daml conventions:
-- invalid preconditions → Right state (no-op), Left for true invariant violations.
module Stablecoin.Test.VaultModel where

import DamlProps.Gen

-- | Vault state as a pure value.
data VaultState = VaultState with
  collateral : Decimal
  debt : Decimal
  price : Decimal
  feeRate : Decimal
  minRatio : Decimal
  liqRatio : Decimal
  liqBonus : Decimal
    deriving (Show, Eq)

-- | Create the default initial state (vault just opened with collateral, no debt).
mkInitialState : VaultState
mkInitialState = VaultState with
  collateral = 10.0
  debt = 0.0
  price = 2000.0
  feeRate = 0.02
  minRatio = 1.5
  liqRatio = 1.3
  liqBonus = 0.13

-- | Actions that can be performed on the vault state.
data VaultAction
  = Deposit Decimal
  | Withdraw Decimal
  | Mint Decimal
  | Burn Decimal
  | CloseVault
  | UpdatePrice Decimal
  | Liquidate
    deriving (Show, Eq)

-- | Calculate collateral ratio.
calcRatio : Decimal -> Decimal -> Decimal -> Decimal
calcRatio collateral debt price =
  if debt == 0.0 then 999999.0
  else (collateral * price) / debt

-- | Execute a vault action. Invalid preconditions → Right state (no-op).
executeVaultAction : VaultState -> VaultAction -> Either Text VaultState
executeVaultAction state (Deposit amt) =
  if amt <= 0.0 then Right state
  else Right state with collateral = state.collateral + amt

executeVaultAction state (Withdraw amt) =
  if amt <= 0.0 then Right state
  else if amt > state.collateral then Right state
  else
    let newCollateral = state.collateral - amt
        ratio = calcRatio newCollateral state.debt state.price
    in if state.debt > 0.0 && ratio < state.minRatio then Right state
    else if newCollateral <= 0.0 then Right state
    else Right state with collateral = newCollateral

executeVaultAction state (Mint amt) =
  if amt <= 0.0 then Right state
  else
    let newDebt = state.debt + amt
        ratio = calcRatio state.collateral newDebt state.price
    in if ratio < state.minRatio then Right state
    else Right state with debt = newDebt

executeVaultAction state (Burn amt) =
  if amt <= 0.0 then Right state
  else if amt > state.debt then Right state
  else Right state with debt = state.debt - amt

executeVaultAction state CloseVault =
  if state.debt > 0.0 then Right state
  else Right state with collateral = 0.0

executeVaultAction state (UpdatePrice newPrice) =
  if newPrice <= 0.0 then Right state
  else Right state with price = newPrice

executeVaultAction state Liquidate =
  if state.debt <= 0.0 then Right state
  else
    let ratio = calcRatio state.collateral state.debt state.price
    in if ratio >= state.liqRatio then Right state
    else
      let seize = (state.debt * (1.0 + state.liqBonus)) / state.price
      in if seize >= state.collateral
         then Right state with
           collateral = 0.0
           debt = 0.0
         else Right state with
           collateral = state.collateral - seize
           debt = 0.0

-- | Check all vault invariants.
checkVaultInvariants : VaultState -> Either Text ()
checkVaultInvariants state
  | state.collateral < 0.0 =
      Left ("Negative collateral: " <> show state.collateral)
  | state.debt < 0.0 =
      Left ("Negative debt: " <> show state.debt)
  | state.price <= 0.0 =
      Left ("Non-positive price: " <> show state.price)
  | otherwise = Right ()

-- | Generate a random vault action.
genVaultAction : Gen VaultAction
genVaultAction = genOneOf
  [ genDeposit
  , genWithdraw
  , genMint
  , genBurn
  , genClose
  , genUpdatePrice
  , genLiquidate
  ]

genDeposit : Gen VaultAction
genDeposit = genMap Deposit (genDecimal 0.01 100.0)

genWithdraw : Gen VaultAction
genWithdraw = genMap Withdraw (genDecimal 0.01 50.0)

genMint : Gen VaultAction
genMint = genMap Mint (genDecimal 1.0 50000.0)

genBurn : Gen VaultAction
genBurn = genMap Burn (genDecimal 1.0 50000.0)

genClose : Gen VaultAction
genClose = genPure CloseVault

genUpdatePrice : Gen VaultAction
genUpdatePrice = genMap UpdatePrice (genDecimal 100.0 10000.0)

genLiquidate : Gen VaultAction
genLiquidate = genPure Liquidate
